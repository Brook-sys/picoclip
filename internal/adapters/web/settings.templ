package web

import "strconv"

templ SettingsPage(view SettingsView) {
	@PageShell("settings", "Settings", "Global configuration, environment variables, and system administration.", nil) {
		<section class="detail-grid">
			<aside class="side-column">
				<nav class="side-nav">
					<a class="nav-link" href="#general">General</a>
					<a class="nav-link" href="#appearance">Appearance</a>
					<a class="nav-link" href="#storage">Storage</a>
					<a class="nav-link" href="#runtimes">Runtimes</a>
					<a class="nav-link" href="#environment">Environment</a>
					<a class="nav-link text-danger" href="#danger-zone">Danger Zone</a>
				</nav>
				
				<div class="panel">
					<h2>System Status</h2>
					@PropertyList() {
						@PropertyItem("Agents", strconv.Itoa(view.Stats.Agents))
						@PropertyItem("Tasks", strconv.Itoa(view.Stats.Tasks))
						@PropertyItem("Projects", strconv.Itoa(view.Stats.Projects))
						@PropertyItem("Skills", strconv.Itoa(view.Stats.Skills))
					}
				</div>
			</aside>
			
			<div class="main-column">
				<div id="general" class="panel">
					<h2>General Settings</h2>
					<p class="muted">Basic application behaviors.</p>
					<form hx-post="/settings/general" hx-target="body" hx-swap="outerHTML" data-success="General settings saved." class="stacked">
						<label>Theme Preference</label>
						<select name="theme">
							<option value="system" selected?={ view.General.Theme == "system" }>System</option>
							<option value="light" selected?={ view.General.Theme == "light" }>Light</option>
							<option value="dark" selected?={ view.General.Theme == "dark" }>Dark</option>
						</select>
						
						<label>Interface Density</label>
						<select name="density">
							<option value="comfortable" selected?={ view.General.Density == "comfortable" }>Comfortable</option>
							<option value="compact" selected?={ view.General.Density == "compact" }>Compact</option>
						</select>
						
						<label>System Log Level</label>
						<select name="log_level">
							<option value="debug" selected?={ view.General.LogLevel == "debug" }>Debug</option>
							<option value="info" selected?={ view.General.LogLevel == "info" }>Info</option>
							<option value="error" selected?={ view.General.LogLevel == "error" }>Error</option>
						</select>
						
						<label>Max Task Retries</label>
						<input name="max_task_retries" type="number" min="0" max="10" value={ view.General.MaxTaskRetries } />
						
						<button type="submit">Save General</button>
					</form>
				</div>
				
				<div id="appearance" class="panel">
					<h2>Appearance</h2>
					<p class="muted">Visual defaults and interaction density.</p>
					<div class="grid-cols-2">
						<div class="card">
							<strong>Current theme</strong>
							<p class="muted">Controlled by the sidebar selector and saved locally in the browser.</p>
						</div>
						<div class="card">
							<strong>Density</strong>
							<p class="muted">Current: { view.General.Density }. Change it in General Settings.</p>
						</div>
					</div>
				</div>
				
				<div id="storage" class="panel">
					<h2>Storage</h2>
					<p class="muted">Database and file management.</p>
					@PropertyList() {
						@PropertyItem("Driver", "SQLite (modernc.org/sqlite)")
						@PropertyItem("Database Path", "data/picoclip.db")
						@PropertyItem("Migrations", "Version 2 applied")
					}
				</div>
				
				<div id="runtimes" class="panel">
					<h2>Agent Runtimes</h2>
					<p class="muted">Manage the execution backends (like Crush or PicoClaw) used by agents to run tasks.</p>
					
					<div class="grid-cols-2" style="margin-top: var(--space-4);">
						for _, r := range view.Runtimes {
							<div class="card bg-surface" style="border-color: var(--border);">
								<div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-2);">
									<h3 style="margin: 0;">{ r.Name }</h3>
									if r.Configured {
										<span class="badge" style="background-color: var(--success-bg); color: var(--success); border: 1px solid var(--success-border);">Installed</span>
									} else {
										<span class="badge" style="background-color: var(--surface-hover); color: var(--muted); border: 1px solid var(--border);">Not configured</span>
									}
								</div>
								<p class="muted" style="margin-top: 0; font-size: 0.9em;">{ r.Description }</p>
								
								<div style="margin-top: var(--space-3); padding-top: var(--space-3); border-top: 1px solid var(--border);">
									if !r.Configured {
										<form hx-post={ "/runtimes/" + string(r.ID) + "/install" } hx-target="body" hx-swap="outerHTML" style="display: flex; gap: var(--space-2);">
											<select name="mode" style="flex: 1;">
												<option value="exclusive">Install Exclusive (Sandboxed)</option>
												<option value="global">Install Global (~/.local/bin)</option>
											</select>
											<button class="button secondary" type="submit" data-loading-disable>Install</button>
										</form>
										<form hx-post={ "/runtimes/" + string(r.ID) + "/existing" } hx-target="body" hx-swap="outerHTML" style="display: flex; gap: var(--space-2); margin-top: var(--space-2);">
											<input type="text" name="bin_path" placeholder="/usr/bin/..." style="flex: 1;" required />
											<button class="button secondary" type="submit">Use Existing</button>
										</form>
									} else {
										<div style="font-size: 0.9em; margin-bottom: var(--space-3);">
											<strong>Path:</strong> <code style="word-break: break-all;">{ r.State.BinPath }</code><br/>
											if r.State.ConfigPath != "" {
												<strong>Config:</strong> <code style="word-break: break-all;">{ r.State.ConfigPath }</code><br/>
											}
											<strong>Health:</strong> 
											if r.Health.Status == "ok" {
												<span style="color: var(--success);">{ r.Health.Version }</span>
											} else {
												<span class="text-danger">{ r.Health.Status }</span>
											}
										</div>
										if len(r.ConfigFiles) > 0 {
											for _, file := range r.ConfigFiles {
												<form hx-post={ "/runtimes/" + string(r.ID) + "/config" } hx-target="body" hx-swap="outerHTML" class="stacked" data-success="Runtime config saved." style="margin-top: var(--space-3);">
													<strong>{ file.Name }</strong>
													if file.Sensitive {
														<span class="badge text-danger" style="margin-left: 8px;">Sensitive</span>
													}
													<input type="hidden" name="file_name" value={ file.Name } />
													<textarea name="content" spellcheck="false" style="font-family: monospace; min-height: 120px; font-size: 12px; white-space: pre;">{ string(file.Content) }</textarea>
													<button class="button secondary" type="submit">Save { file.Name }</button>
												</form>
											}
										} else if r.State.ConfigPath != "" {
											<form hx-post={ "/runtimes/" + string(r.ID) + "/config" } hx-target="body" hx-swap="outerHTML" class="stacked" data-success="Runtime config saved.">
												<input type="hidden" name="file_name" value="config.json" />
												<textarea name="content" spellcheck="false" style="font-family: monospace; min-height: 120px; font-size: 12px;"></textarea>
												<button class="button secondary" type="submit">Save Config</button>
											</form>
										}
									}
								</div>
							</div>
						}
					</div>
				</div>
				
				<div id="environment" class="panel">
					<h2>Environment Variables</h2>
					<p class="muted">Global variables injected into task execution (e.g., API keys). One per line (KEY=value).</p>
					<form hx-post="/settings/environment" hx-target="body" hx-swap="outerHTML" data-success="Environment saved." class="stacked">
						<textarea name="environment" placeholder="OPENAI_API_KEY=sk-...\nDATABASE_URL=postgres://..." spellcheck="false" style="font-family: monospace; min-height: 140px;">{ formatEnvText(view.Environment) }</textarea>
						<button type="submit">Save Environment</button>
					</form>
				</div>
				
				<div id="danger-zone" class="panel border-danger">
					<h2 class="text-danger">Danger Zone</h2>
					<p class="muted">Destructive operations for this PicoClip instance.</p>

					<div class="card bg-surface" style="margin-top: var(--space-4); border-color: var(--border);">
						<h3>Export Backup</h3>
						<p class="muted">Download agents, projects, tasks, runs, messages, skills, events and settings as JSON.</p>
						<a class="button secondary" href="/settings/export" download="picoclip-backup.json" style="margin-top: 8px;">Download Backup JSON</a>
					</div>
					
					<div class="card bg-surface" style="margin-top: 16px; border-color: var(--border);">
						<h3>Restore Backup</h3>
						<p class="muted">Import a PicoClip backup JSON. This replaces the current database content.</p>
						<form hx-post="/settings/import" hx-encoding="multipart/form-data" hx-confirm="Importing a backup will replace current data. Continue?" hx-target="body" hx-swap="outerHTML" class="stacked" style="margin-top: 8px;">
							<input type="file" name="backup_file" accept="application/json,.json" required/>
							<button class="button secondary" type="submit">Restore JSON</button>
						</form>
					</div>

					<div class="card bg-danger-light" style="margin-top: 16px;">
						<h3>Factory Reset</h3>
						<p>This will permanently delete all agents, tasks, runs, messages, projects, custom skills and history. Built-in skills will be restored. This action cannot be undone.</p>
						<button class="button button-danger" type="button" data-open-modal="reset-modal" style="margin-top: var(--space-2);">Reset All Data</button>
					</div>
				</div>
			</div>
		</section>
		@ResetModal("reset-modal")
	}
}

templ ResetModal(id string) {
	<div class="modal-backdrop" data-modal={ id } hidden style="display: none;">
		<div class="modal-card border-danger">
			<button class="modal-close" type="button" data-close-modal={ id }>×</button>
			<h2 class="text-danger">Reset All Data</h2>
			<p>Are you absolutely sure? This will wipe the entire database and cannot be recovered.</p>
			
			<form hx-post="/settings/reset" hx-target="body" hx-swap="outerHTML" class="stacked" style="margin-top: var(--space-4);">
				<label for="confirm_text">Please type <strong>RESET</strong> to confirm:</label>
				<input id="confirm_text" name="confirm_text" type="text" autocomplete="off" required pattern="RESET" title="Type RESET to confirm" />
				<div class="actions" style="margin-top: var(--space-4);">
					<button class="button" type="button" data-close-modal={ id }>Cancel</button>
					<button class="button button-danger" type="submit">Yes, Reset Data</button>
				</div>
			</form>
		</div>
	</div>
}

func adapterSetting(settings map[string]map[string]string, adapter string, key string) string {
	if settings == nil || settings[adapter] == nil {
		return ""
	}
	return settings[adapter][key]
}
