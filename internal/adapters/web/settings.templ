package web

import "strconv"

templ SystemStatusCard(label string, value string, iconName string, variant string) {
	<div class={ "system-status-card", "system-status-" + variant }>
		<span class="system-status-icon" aria-hidden="true">
			@Icon(iconName, 18)
		</span>
		<span class="system-status-content">
			<small>{ label }</small>
			<strong>{ value }</strong>
		</span>
	</div>
}

templ RuntimeStatusTile(label string, status string, testedAt string, ok bool, tested bool) {
	<div class={ "runtime-status-tile", runtimeStatusClass(ok, tested) }>
		<span class="runtime-status-icon" aria-hidden="true">
			if ok {
				@Icon("check", 16)
			} else if tested {
				@Icon("x", 16)
			} else {
				@Icon("settings", 16)
			}
		</span>
		<span class="runtime-status-copy">
			<small>{ label }</small>
			<strong>{ status }</strong>
			if testedAt != "" {
				<em>{ "Last tested: " + testedAt }</em>
			} else {
				<em>Awaiting first test</em>
			}
		</span>
	</div>
}

templ RuntimePathRow(label string, value string) {
	if value != "" {
		<div class="runtime-path-row">
			<span>
				<small>{ label }</small>
				<code>{ value }</code>
			</span>
			<button class="runtime-copy-button" type="button" data-copy-text={ value }>Copy</button>
		</div>
	}
}

templ RuntimeConfiguredCard(r RuntimeCardView) {
	<div class={ "runtime-health-card", runtimeOverallClass(r) }>
		<div class="runtime-health-header">
			<div>
				<h3>{ r.Name }</h3>
				<p>{ r.Description }</p>
			</div>
			<div class="runtime-health-badges">
				<span class={ "runtime-overall-badge", runtimeOverallBadgeClass(r) }>{ runtimeOverallLabel(r) }</span>
				if r.Health.Version != "" {
					<span class="runtime-version-badge">{ r.Health.Version }</span>
				}
			</div>
		</div>
		<div class="runtime-status-grid">
			@RuntimeStatusTile("CLI", runtimeCLIStatusLabel(r), r.TestedAt, r.Functional, r.Tested)
			@RuntimeStatusTile("AI", runtimeAIStatusLabel(r), r.AITestedAt, r.AIOk, r.AITested)
		</div>
		<div class="runtime-path-list">
			@RuntimePathRow("Binary", r.State.BinPath)
			@RuntimePathRow("Config", r.State.ConfigPath)
		</div>
		if r.AIMessage != "" || r.AIOutput != "" {
			<div class={ "runtime-ai-result", runtimeAIResultClass(r) }>
				<div class="runtime-ai-result-header">
					<span class="runtime-ai-result-icon">
						if r.AIOk {
							@Icon("check", 16)
						} else {
							@Icon("x", 16)
						}
					</span>
					<strong>{ runtimeAIMessage(r) }</strong>
				</div>
				if r.AIOutput != "" {
					<details class="runtime-raw-output">
						<summary>Raw AI test output</summary>
						<pre>{ r.AIOutput }</pre>
					</details>
				}
			</div>
		}
		if len(r.Checks) > 0 && !r.Functional {
			<div class="runtime-check-list">
				for _, check := range r.Checks {
					<div class={ "runtime-check-item", templ.KV("runtime-check-error", check.Status == "error") }>
						<strong>{ check.Name }</strong>
						<span>{ check.Status }</span>
						<small>{ check.Message }</small>
					</div>
				}
			</div>
		}
		<div class="runtime-action-bar">
			<form hx-post={ "/runtimes/" + string(r.ID) + "/test" } data-no-toast="true" hx-target="body" hx-swap="outerHTML">
				<button class="pc-btn pc-btn-secondary" type="submit" data-loading-text="Testing CLI...">@Icon("play", 16) Test CLI</button>
			</form>
			<form hx-post={ "/runtimes/" + string(r.ID) + "/test-ai" } hx-confirm="This will send a real test request to the configured AI provider. It may consume tokens. Continue?" data-no-toast="true" hx-target="body" hx-swap="outerHTML">
				<button class="pc-btn pc-btn-secondary" type="submit" data-loading-text="Testing AI...">@Icon("zap", 16) Test AI</button>
			</form>
			<form hx-post={ "/runtimes/" + string(r.ID) + "/uninstall" } hx-confirm="Are you sure you want to uninstall this runtime? Configuration files will be deleted if installed exclusively." hx-target="body" hx-swap="outerHTML">
				<button class="pc-btn pc-btn-ghost runtime-danger-action" type="submit">@Icon("trash", 16) Uninstall</button>
			</form>
		</div>
	</div>
}

templ RuntimeConfigEditors(r RuntimeCardView) {
	if len(r.ConfigFiles) > 0 {
		for _, file := range r.ConfigFiles {
			<form hx-post={ "/runtimes/" + string(r.ID) + "/config" } hx-target="body" hx-swap="outerHTML" class="runtime-config-editor" data-success="Runtime config saved.">
				<div class="runtime-config-header">
					<strong>{ file.Name }</strong>
					if file.Sensitive {
						<span class="pc-badge pc-badge-bad">Sensitive</span>
					}
				</div>
				<input type="hidden" name="file_name" value={ file.Name } />
				<textarea name="content" spellcheck="false">{ string(file.Content) }</textarea>
				<button class="pc-btn pc-btn-secondary" type="submit">Save { file.Name }</button>
			</form>
		}
	} else if r.State.ConfigPath != "" {
		<form hx-post={ "/runtimes/" + string(r.ID) + "/config" } hx-target="body" hx-swap="outerHTML" class="runtime-config-editor" data-success="Runtime config saved.">
			<div class="runtime-config-header"><strong>config.json</strong></div>
			<input type="hidden" name="file_name" value="config.json" />
			<textarea name="content" spellcheck="false"></textarea>
			<button class="pc-btn pc-btn-secondary" type="submit">Save Config</button>
		</form>
	}
}

templ SettingsPage(view SettingsView) {
	@PageShell("settings", "Settings", "Global configuration, environment variables, and system administration.", nil) {
		<section class="settings-layout">
			<aside class="settings-sidebar">
				<nav class="side-nav">
					<a class="nav-link" href="#general">General</a>
					<a class="nav-link" href="#appearance">Appearance</a>
					<a class="nav-link" href="#storage">Storage</a>
					<a class="nav-link" href="#runtimes">Runtimes</a>
					<a class="nav-link" href="#environment">Environment</a>
					<a class="nav-link text-danger" href="#danger-zone">Danger Zone</a>
				</nav>
				
				<div class="settings-panel">
					<h2>Diagnostics</h2>
					<p class="muted">System health checks.</p>
					<div class="diagnostic-list">
						for _, check := range view.Diagnostics.Checks {
							<div class={ "diagnostic-item", templ.KV("diagnostic-ok", check.Status == "ok"), templ.KV("diagnostic-error", check.Status != "ok") }>
								<span class="diagnostic-icon" aria-hidden="true">
									if check.Status == "ok" {
										@Icon("check", 14)
									} else {
										@Icon("x", 14)
									}
								</span>
								<span class="diagnostic-content">
									<strong>{ check.Name }</strong>
									<small>{ check.Status }</small>
								</span>
							</div>
						}
					</div>
				</div>

				<div class="settings-panel">
					<h2>System Status</h2>
					<p class="muted">Current workspace inventory.</p>
					<div class="system-status-grid">
						@SystemStatusCard("Agents", strconv.Itoa(view.Stats.Agents), "cpu", "agents")
						@SystemStatusCard("Tasks", strconv.Itoa(view.Stats.Tasks), "check-circle", "tasks")
						@SystemStatusCard("Projects", strconv.Itoa(view.Stats.Projects), "folder", "projects")
						@SystemStatusCard("Skills", strconv.Itoa(view.Stats.Skills), "zap", "skills")
					</div>
				</div>
			</aside>
			
			<div class="settings-content">
				<div id="general" class="settings-panel">
					<h2>General Settings</h2>
					<p class="muted">Basic application behaviors.</p>
					<form hx-post="/settings/general" hx-target="body" hx-swap="outerHTML" data-success="General settings saved." class="stacked">
						<label>Theme Preference</label>
						<select name="theme">
							<option value="system" selected?={ view.General.Theme == "system" }>System</option>
							<option value="light" selected?={ view.General.Theme == "light" }>Light</option>
							<option value="dark" selected?={ view.General.Theme == "dark" }>Dark</option>
						</select>
						
						<label>Interface Density</label>
						<select name="density">
							<option value="comfortable" selected?={ view.General.Density == "comfortable" }>Comfortable</option>
							<option value="compact" selected?={ view.General.Density == "compact" }>Compact</option>
						</select>
						
						<label>System Log Level</label>
						<select name="log_level">
							<option value="debug" selected?={ view.General.LogLevel == "debug" }>Debug</option>
							<option value="info" selected?={ view.General.LogLevel == "info" }>Info</option>
							<option value="error" selected?={ view.General.LogLevel == "error" }>Error</option>
						</select>
						
						<label>Max Task Retries</label>
						<input name="max_task_retries" type="number" min="0" max="10" value={ view.General.MaxTaskRetries } />
						
						<button type="submit">Save General</button>
					</form>
				</div>
				
				<div id="appearance" class="settings-panel">
					<h2>Appearance</h2>
					<p class="muted">Visual defaults and interaction density.</p>
					<div class="grid-cols-2">
						<div class="card">
							<strong>Current theme</strong>
							<p class="muted">Controlled by the sidebar selector and saved locally in the browser.</p>
						</div>
						<div class="card">
							<strong>Density</strong>
							<p class="muted">Current: { view.General.Density }. Change it in General Settings.</p>
						</div>
					</div>
				</div>
				
				<div id="storage" class="settings-panel">
					<h2>Storage</h2>
					<p class="muted">Database and file management.</p>
					@PropertyList() {
						@PropertyItem("Driver", view.Diagnostics.StorageType)
						@PropertyItem("Database Path", view.Diagnostics.DatabasePath)
						@PropertyItem("Migrations", "Applied")
					}
				</div>
				
				<div id="runtimes" class="settings-panel">
					<h2>Agent Runtimes</h2>
					<p class="muted">Manage the execution backends (like Crush or PicoClaw) used by agents to run tasks.</p>
					
					<div class="grid-cols-2" style="margin-top: var(--space-4);">
						for _, r := range view.Runtimes {
							<div class="card bg-surface" style="border-color: var(--border);">
								<div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: var(--space-2);">
									<h3 style="margin: 0;">{ r.Name }</h3>
									if r.Configured {
										<span class="badge" style="background-color: var(--success-bg); color: var(--success); border: 1px solid var(--success-border);">Installed</span>
									} else {
										<span class="badge" style="background-color: var(--surface-hover); color: var(--muted); border: 1px solid var(--border);">Not configured</span>
									}
								</div>
								<p class="muted" style="margin-top: 0; font-size: 0.9em;">{ r.Description }</p>
								
								<div style="margin-top: var(--space-3); padding-top: var(--space-3); border-top: 1px solid var(--border);">
									if r.Configured {
									@RuntimeConfiguredCard(r)
									@RuntimeConfigEditors(r)
								} else {
									<form hx-post={ "/runtimes/" + string(r.ID) + "/install" } hx-target="body" hx-swap="outerHTML" data-success="Runtime installed." data-error="Runtime install failed." class="stacked">
										<select name="mode">
											<option value="exclusive">Install Exclusive (Sandboxed)</option>
											<option value="global">Install Global (~/.local/bin)</option>
										</select>
										<input type="text" name="version_alias" value="latest" list={ "versions-" + string(r.ID) } placeholder="latest, nightly, or tag" required />
										<datalist id={ "versions-" + string(r.ID) }>
											<option value="latest">latest</option>
											<option value="nightly">nightly/prerelease</option>
											for _, v := range r.Versions {
												<option value={ v.Tag }>{ v.Label }</option>
											}
										</datalist>
										<p class="muted">Choose latest, nightly, one of the latest 10 releases, or type an exact tag.</p>
										<button class="pc-btn pc-btn-secondary" type="submit" data-loading-disable>@Icon("plus", 16) Install</button>
									</form>
									<form hx-post={ "/runtimes/" + string(r.ID) + "/existing" } hx-target="body" hx-swap="outerHTML" data-success="Existing runtime configured." data-error="Failed to configure existing runtime." class="runtime-existing-form">
										<input type="text" name="bin_path" placeholder="/usr/bin/..." required />
										<button class="pc-btn pc-btn-secondary" type="submit">Use Existing</button>
									</form>
								}
								</div>
							</div>
						}
					</div>
				</div>
				
				<div id="environment" class="settings-panel">
					<h2>Environment Variables</h2>
					<p class="muted">Global variables injected into task execution. Values are hidden by default because they often contain secrets.</p>
					<form hx-post="/settings/environment" hx-target="body" hx-swap="outerHTML" data-success="Environment saved." class="stacked">
						@EnvEditorField(view.Environment)
						<button class="pc-btn pc-btn-primary" type="submit">@Icon("check", 16) Save Environment</button>
					</form>
				</div>
				
				<div id="danger-zone" class="panel border-danger">
					<h2 class="text-danger">Danger Zone</h2>
					<p class="muted">Destructive operations for this PicoClip instance.</p>

					<div class="card bg-surface" style="margin-top: var(--space-4); border-color: var(--border);">
						<h3>Export Backup</h3>
						<p class="muted">Download agents, projects, tasks, runs, messages, skills, events and settings as JSON.</p>
						<a class="button secondary" href="/settings/export" download="picoclip-backup.json" style="margin-top: 8px;">Download Backup JSON</a>
					</div>
					
					<div class="card bg-surface" style="margin-top: 16px; border-color: var(--border);">
						<h3>Restore Backup</h3>
						<p class="muted">Import a PicoClip backup JSON. This replaces the current database content.</p>
						<form hx-post="/settings/import" hx-encoding="multipart/form-data" hx-confirm="Importing a backup will replace current data. Continue?" hx-target="body" hx-swap="outerHTML" class="stacked" style="margin-top: 8px;">
							<input type="file" name="backup_file" accept="application/json,.json" required/>
							<button class="button secondary" type="submit">Restore JSON</button>
						</form>
					</div>

					<div class="card bg-danger-light" style="margin-top: 16px;">
						<h3>Factory Reset</h3>
						<p>This will permanently delete all agents, tasks, runs, messages, projects, custom skills and history. Built-in skills will be restored. This action cannot be undone.</p>
						<button data-testid="settings-reset-all" class="button button-danger" type="button" data-open-modal="reset-modal" style="margin-top: var(--space-2);">Reset All Data</button>
					</div>
				</div>
			</div>
		</section>
		@ResetModal("reset-modal")
	}
}

templ ResetModal(id string) {
	<div class="modal-backdrop" data-modal={ id } hidden style="display: none;">
		<div class="modal-card border-danger">
			<button class="modal-close" type="button" data-close-modal={ id }>×</button>
			<h2 class="text-danger">Reset All Data</h2>
			<p>Are you absolutely sure? This will wipe the entire database and cannot be recovered.</p>
			
			<form hx-post="/settings/reset" hx-target="body" hx-swap="outerHTML" class="stacked" style="margin-top: var(--space-4);">
				<label for="confirm_text">Please type <strong>RESET</strong> to confirm:</label>
				<input id="confirm_text" name="confirm_text" type="text" autocomplete="off" required pattern="RESET" title="Type RESET to confirm" />
				<div class="actions" style="margin-top: var(--space-4);">
					<button class="button" type="button" data-close-modal={ id }>Cancel</button>
					<button data-testid="settings-reset-confirm" class="button button-danger" type="submit">Yes, Reset Data</button>
				</div>
			</form>
		</div>
	</div>
}

func runtimeStatusClass(ok bool, tested bool) string {
	if !tested {
		return "runtime-status-warn"
	}
	if ok {
		return "runtime-status-ok"
	}
	return "runtime-status-error"
}

func runtimeCLIStatusLabel(r RuntimeCardView) string {
	if !r.Tested {
		return "Not tested"
	}
	if r.Functional {
		return "Functional"
	}
	return "Not functional"
}

func runtimeAIStatusLabel(r RuntimeCardView) string {
	if !r.AITested {
		return "Not tested"
	}
	if r.AIOk {
		return "Functional"
	}
	return "Failed"
}

func runtimeOverallClass(r RuntimeCardView) string {
	if !r.Tested || !r.AITested {
		return "runtime-health-warn"
	}
	if r.Functional && r.AIOk {
		return "runtime-health-ok"
	}
	return "runtime-health-error"
}

func runtimeOverallBadgeClass(r RuntimeCardView) string {
	if !r.Tested || !r.AITested {
		return "runtime-overall-warn"
	}
	if r.Functional && r.AIOk {
		return "runtime-overall-ok"
	}
	return "runtime-overall-error"
}

func runtimeOverallLabel(r RuntimeCardView) string {
	if !r.Tested || !r.AITested {
		return "Needs test"
	}
	if r.Functional && r.AIOk {
		return "Healthy"
	}
	return "Attention needed"
}

func runtimeAIResultClass(r RuntimeCardView) string {
	if r.AIOk {
		return "runtime-ai-ok"
	}
	return "runtime-ai-error"
}

func runtimeAIMessage(r RuntimeCardView) string {
	if r.AIMessage != "" {
		return r.AIMessage
	}
	if r.AIOk {
		return "AI request successful"
	}
	return "AI request failed"
}

func adapterSetting(settings map[string]map[string]string, adapter string, key string) string {
	if settings == nil || settings[adapter] == nil {
		return ""
	}
	return settings[adapter][key]
}
