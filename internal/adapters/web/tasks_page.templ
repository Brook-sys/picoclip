package web

import (
	"fmt"

	"picoclip/internal/core/domain"
)

templ TasksPage(tasks []taskResponse, allTasks []taskResponse, agents []domain.Agent, projects []domain.Workspace, activeTab string) {
	@PageShell("tasks", "Tasks", "Issue-style queue for work, delegation, review and agent execution.", tasksAction()) {
		<div id="tasks-live" hx-get={ templ.URL("/partials/tasks-page?status=" + activeTab) } hx-trigger="picoclip-live from:body throttle:1500ms, every 30s" hx-swap="innerHTML">
			@TasksLive(tasks, allTasks, agents, projects, activeTab)
		</div>
		@TaskModal("task-create-modal", "", projects, agents)
	}
}

templ TasksLive(tasks []taskResponse, allTasks []taskResponse, agents []domain.Agent, projects []domain.Workspace, activeTab string) {
	<section class="tasks-overview-grid">
			<a class="panel tasks-overview-card" href="/tasks">
				<span>Total</span>
				<strong>{ fmt.Sprintf("%d", len(allTasks)) }</strong>
				<small>All tasks</small>
			</a>
			<a class="panel tasks-overview-card queued" href="/tasks?status=todo">
				<span>Todo</span>
				<strong>{ fmt.Sprintf("%d", taskStatusCount(allTasks, domain.TaskStatusTodo)) }</strong>
				<small>Waiting to run</small>
			</a>
			<a class="panel tasks-overview-card live" href="/tasks?status=in_progress">
				<span>In Progress</span>
				<strong>{ fmt.Sprintf("%d", taskStatusCount(allTasks, domain.TaskStatusInProgress)) }</strong>
				<small>Currently executing</small>
			</a>
			<a class="panel tasks-overview-card review" href="/tasks?status=in_review">
				<span>Review</span>
				<strong>{ fmt.Sprintf("%d", taskStatusCount(allTasks, domain.TaskStatusInReview)) }</strong>
				<small>Awaiting review</small>
			</a>
			<a class="panel tasks-overview-card attention" href="/tasks?status=blocked">
				<span>Attention</span>
				<strong>{ fmt.Sprintf("%d", taskAttentionCount(allTasks)) }</strong>
				<small>Blocked or needs action</small>
			</a>
			<a class="panel tasks-overview-card success" href="/tasks?status=done">
				<span>Done</span>
				<strong>{ fmt.Sprintf("%d", taskStatusCount(allTasks, domain.TaskStatusDone)) }</strong>
				<small>Completed work</small>
			</a>
		</section>
		<div class="runs-toolbar">
			@Tabs() {
				@TabLink("All", "/tasks", activeTab == "" || activeTab == "all")
				@TabLink("Todo", "/tasks?status=todo", activeTab == "todo")
				@TabLink("In Progress", "/tasks?status=in_progress", activeTab == "in_progress")
				@TabLink("Review", "/tasks?status=in_review", activeTab == "in_review")
				@TabLink("Blocked", "/tasks?status=blocked", activeTab == "blocked")
				@TabLink("Done", "/tasks?status=done", activeTab == "done")
			}
		</div>
	<section class="panel tasks-panel">
			<div class="tasks-panel-header">
				<div>
					<span class="eyebrow">Work queue</span>
					<h2>Task board</h2>
					<p>Live queue refreshes automatically while agents work.</p>
				</div>
				<div class="cleanup-actions">
					<span class="runs-filter-pill">{ taskFilterLabel(activeTab) }</span>
					<form method="post" action="/tasks/cleanup-finished" hx-post="/tasks/cleanup-finished" hx-target="body" hx-swap="outerHTML" hx-confirm="Delete only finished tasks (done/cancelled)? Running tasks will be kept.">
						<button class="activity-action button-danger" type="submit">Delete finished</button>
					</form>
				</div>
			</div>
			@TaskTable(tasks, agents, projects)
		</section>
}

templ tasksAction() {
	<button data-testid="task-create-button" class="pc-btn pc-btn-primary" type="button" data-open-modal="task-create-modal">Nova task</button>
}

func taskStatusCount(tasks []taskResponse, status domain.TaskStatus) int {
	count := 0
	for _, t := range tasks {
		if domain.TaskStatus(t.Status) == status {
			count++
		}
	}
	return count
}

func taskAttentionCount(tasks []taskResponse) int {
	count := 0
	for _, t := range tasks {
		if domain.TaskStatus(t.Status) == domain.TaskStatusBlocked {
			count++
		}
	}
	return count
}

func taskFilterLabel(activeTab string) string {
	switch activeTab {
	case "", "all":
		return "All tasks"
	case "todo":
		return "Todo"
	case "in_progress":
		return "In Progress"
	case "in_review":
		return "Review"
	case "blocked":
		return "Blocked"
	case "done":
		return "Done"
	default:
		return activeTab
	}
}

func taskListSummary(tasks []taskResponse) string {
	if len(tasks) == 1 {
		return "1 task in this view"
	}
	return fmt.Sprintf("%d tasks in this view", len(tasks))
}
