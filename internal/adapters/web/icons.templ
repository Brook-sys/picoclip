package web

import "fmt"

templ Icon(name string, size int) {
	if name == "check" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-check"><polyline points="20 6 9 17 4 12"></polyline></svg>
	} else if name == "x" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-x"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
	} else if name == "chevron-down" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-chevron-down"><polyline points="6 9 12 15 18 9"></polyline></svg>
	} else if name == "chevron-right" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-chevron-right"><polyline points="9 18 15 12 9 6"></polyline></svg>
	} else if name == "plus" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-plus"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
	} else if name == "trash" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-trash"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
	} else if name == "settings" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-settings"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
	} else if name == "play" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-play"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
	} else if name == "stop" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-stop"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>
	} else if name == "users" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-users"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
	} else if name == "folder" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-folder"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
	} else if name == "check-circle" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-check-circle"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
	} else if name == "cpu" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-cpu"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="23"></line><line x1="15" y1="20" x2="15" y2="23"></line><line x1="20" y1="9" x2="23" y2="9"></line><line x1="20" y1="14" x2="23" y2="14"></line><line x1="1" y1="9" x2="4" y2="9"></line><line x1="1" y1="14" x2="4" y2="14"></line></svg>
	} else if name == "zap" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-zap"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
	} else if name == "book" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-book"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
	} else if name == "bar-chart" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-bar-chart"><line x1="12" y1="20" x2="12" y2="10"></line><line x1="18" y1="20" x2="18" y2="4"></line><line x1="6" y1="20" x2="6" y2="16"></line></svg>
	} else if name == "eye" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-eye"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
	} else if name == "eye-off" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-eye-off"><path d="m15 18-.722-3.25"></path><path d="M2 8a10.645 10.645 0 0 0 20 0"></path><path d="m20 15-1.726-2.05"></path><path d="m4 15 1.726-2.05"></path><path d="m9 18 .722-3.25"></path></svg>
	} else if name == "list" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-list"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
	} else if name == "alert-triangle" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-alert-triangle"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
	} else if name == "x-circle" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-x-circle"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
	} else if name == "alert-circle" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-alert-circle"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
	} else if name == "rocket" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-rocket"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"></path><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c-2.78 1.2-5.12 4.18-6.05 7.05A22 22 0 0 1 15 12z"></path><path d="M9 12H4.5a2.5 2.5 0 0 1 0-5H9"></path><path d="M14 19v4.5a2.5 2.5 0 0 1-5 0V19"></path></svg>
	} else if name == "activity" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-activity"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
	} else if name == "clock" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pc-icon pc-icon-clock"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
	} else if name == "layout-dashboard" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"></rect><rect width="7" height="5" x="14" y="3" rx="1"></rect><rect width="7" height="9" x="14" y="12" rx="1"></rect><rect width="7" height="5" x="3" y="16" rx="1"></rect></svg>
	} else if name == "check-square" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg>
	} else if name == "play-circle" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polygon points="10 8 16 12 10 16 10 8"></polygon></svg>
	} else if name == "sparkles" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"></path><path d="M5 3v4"></path><path d="M19 17v4"></path><path d="M3 5h4"></path><path d="M17 19h4"></path></svg>
	} else if name == "bot" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="10" x="3" y="11" rx="2"></rect><circle cx="12" cy="5" r="2"></circle><path d="M12 7v4"></path><line x1="8" x2="8" y1="16" y2="16"></line><line x1="16" x2="16" y1="16" y2="16"></line></svg>
	} else if name == "paperclip" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48"></path></svg>
	} else if name == "circle" {
		<svg xmlns="http://www.w3.org/2000/svg" width={ stringifyInt(size) } height={ stringifyInt(size) } viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle></svg>
	}
}

func stringifyInt(i int) string {
	return fmt.Sprintf("%d", i)
}
