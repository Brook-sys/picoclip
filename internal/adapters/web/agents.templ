package web

import (
	"fmt"

	"picoclip/internal/core/domain"
)

templ AgentsPage(agents []domain.Agent, projects []domain.Workspace, tasks []taskResponse, runtimeOptions []RuntimeOption) {
	@PageShell("agents", "Agents", "Local workers with runtimes, skills, permissions and assigned workload.", agentsAction()) {
		<div class="stack">
			<section class="list-toolbar">
				<div>
					<strong>{ agentListSummary(agents) }</strong>
					<p>Monitor availability, runtime health, permissions and workload.</p>
				</div>
			</section>
			<section class="panel list-panel">
				@SectionHeader("Agent Workforce", "Filter by tags and inspect operational readiness.") {}
				<div class="list-filter-row">
					@TagFilterLinks(agents)
				</div>
				<div class="table-wrapper">
				<table>
					<thead>
						<tr>
							<th>Agent</th>
							<th>Status</th>
							<th>Role</th>
							<th>Tags</th>
							<th>Runtime</th>
							<th>Permissions</th>
							<th>Tasks</th>
						</tr>
					</thead>
					<tbody>
						if len(agents) == 0 {
							<tr><td colspan="7" class="empty">No agents created yet.</td></tr>
						}
						for _, agent := range agents {
							<tr class={ "agent-list-row", templ.KV("agent-list-row-disabled", !agent.Enabled) }>
								<td>
									<div class="agent-list-identity">
										<span class="agent-list-avatar">@Icon("cpu", 16)</span>
										<span>
											<a class="primary-link" href={ templ.URL("/agents/" + agent.ID) }>{ agent.Name }</a>
											<small>{ agent.Description }</small>
										</span>
									</div>
								</td>
								<td>
									if agent.Enabled {
										@Badge("enabled", "good")
									} else {
										@Badge("disabled", "bad")
									}
								</td>
								<td><span class="agent-role-pill">{ agentTitle(agent) }</span></td>
								<td>@TagChips(agentDisplayTags(agent, projects))</td>
								<td>
									if agent.Type != "noop" && !isRuntimeValid(string(agent.Type), runtimeOptions) {
										<span class="agent-runtime-warning" title="Runtime indisponível ou desabilitado">@Icon("alert-triangle", 12) { string(agent.Type) }</span>
									} else {
										<span class="agent-runtime-badge">@Icon("play", 12) { string(agent.Type) }</span>
									}
								</td>
								<td><span class="agent-stat-pill">{ len(agent.Permissions) } permissions</span></td>
								<td><span class="agent-workload-pill">{ countTasksForAgent(tasks, agent.ID) } tasks</span></td>
							</tr>
						}
					</tbody>
				</table>
				</div>
			</section>
		</div>
		@AgentQuickModal("agent-quick-modal", agents, runtimeOptions)
	}
}

templ agentsAction() {
	<button data-testid="agent-create-button" class="pc-btn pc-btn-primary" type="button" data-open-modal="agent-quick-modal">
		@Icon("plus", 16)
		Novo agente
	</button>
}

templ TagFilterLinks(agents []domain.Agent) {
	@templ.Raw(renderTagFilterLinks(agents))
}

func agentTitle(agent domain.Agent) string {
	if agent.Title != "" {
		return agent.Title
	}
	if agent.Capability != "" {
		return string(agent.Capability)
	}
	return "worker"
}

func agentListSummary(agents []domain.Agent) string {
	if len(agents) == 1 {
		return "1 agent configured"
	}
	return fmt.Sprintf("%d agents configured", len(agents))
}

func isRuntimeValid(id string, options []RuntimeOption) bool {
	for _, opt := range options {
		if string(opt.ID) == id {
			return true
		}
	}
	return false
}
