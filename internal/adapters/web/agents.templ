package web

import "picoclip/internal/core/domain"

templ AgentsPage(agents []domain.Agent, projects []domain.Workspace, tasks []taskResponse) {
	@PageShell("agents", "Agents", "Local workers with drivers, skills, permissions and assigned workload.", agentsAction()) {
		<section class="panel">
			@SectionHeader("Agent Workforce", "Monitor available agents and their task load.") {}
			<div class="stack-sm" style="margin-bottom: 16px;">
				@TagFilterLinks(agents)
			</div>
			<div class="table-wrapper">
				<table>
					<thead>
						<tr>
							<th>Agent</th>
							<th>Status</th>
							<th>Role</th>
							<th>Tags</th>
							<th>Driver</th>
							<th>Permissions</th>
							<th>Tasks</th>
						</tr>
					</thead>
					<tbody>
						if len(agents) == 0 {
							<tr><td colspan="7" class="empty">No agents created yet.</td></tr>
						}
						for _, agent := range agents {
							<tr>
								<td>
									<a class="primary-link" href={ templ.URL("/agents/" + agent.ID) }>{ agent.Name }</a>
									<small>{ agent.Description }</small>
								</td>
								<td>
									if agent.Enabled {
										@Badge("enabled", "good")
									} else {
										@Badge("disabled", "bad")
									}
								</td>
								<td>{ agent.Title }</td>
								<td>@TagChips(agentDisplayTags(agent, projects))</td>
								<td>{ string(agent.Type) }</td>
								<td><span class="badge">{ len(agent.Permissions) }</span></td>
								<td>{ countTasksForAgent(tasks, agent.ID) }</td>
							</tr>
						}
					</tbody>
				</table>
			</div>
		</section>
		@AgentQuickModal("agent-quick-modal", agents)
	}
}

templ agentsAction() {
	<button data-testid="agent-create-button" class="button" type="button" data-open-modal="agent-quick-modal">Novo agente</button>
}

templ TagFilterLinks(agents []domain.Agent) {
	@templ.Raw(renderTagFilterLinks(agents))
}
