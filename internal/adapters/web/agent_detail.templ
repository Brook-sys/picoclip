package web

import "picoclip/internal/core/domain"
import "strings"

templ AgentDetailPage(agent domain.Agent, agents []domain.Agent, tasks []taskResponse, projects []domain.Workspace, runs []domain.Run, skills []domain.Skill) {
	@PageShell("agents", agent.Name, agent.Description, agentDetailAction()) {
		@Tabs() {
			@TabLink("Overview", "#overview", true)
			@TabLink("Tasks", "#tasks", false)
			@TabLink("Runs", "#runs", false)
			@TabLink("Configuration", "#configuration", false)
			@TabLink("Permissions", "#permissions", false)
		}
		<section class="content-grid">
			<div class="main-column">
				<div id="overview" class="agent-profile-card">
					<div class="agent-profile-header">
						<div class="agent-avatar" aria-hidden="true">
							@Icon("cpu", 24)
						</div>
						<div class="agent-profile-heading">
							<div class="agent-profile-title-row">
								<strong class="agent-profile-name">{ agent.Name }</strong>
								if agent.Enabled {
									<span class="pc-badge pc-badge-good">Enabled</span>
								} else {
									<span class="pc-badge pc-badge-bad">Disabled</span>
								}
							</div>
							<p>{ agentDescriptionText(agent.Description) }</p>
						</div>
					</div>
					<div class="agent-overview-grid">
						<div class="agent-overview-tile agent-overview-wide">
							<span class="agent-overview-icon">@Icon("book", 16)</span>
							<span class="agent-overview-content">
								<small>Agent ID</small>
								<code>{ agent.ID }</code>
							</span>
							<button class="runtime-copy-button" type="button" data-copy-text={ agent.ID }>Copy</button>
						</div>
						<div class="agent-overview-tile">
							<span class="agent-overview-icon">@Icon("users", 16)</span>
							<span class="agent-overview-content">
								<small>Title</small>
								<strong>{ agentFallbackText(agent.Title, "No title set") }</strong>
							</span>
						</div>
						<div class="agent-overview-tile">
							<span class="agent-overview-icon">@Icon("chevron-right", 16)</span>
							<span class="agent-overview-content">
								<small>Reports to</small>
								<strong>{ agentReportsToText(agents, agent.ReportsToID) }</strong>
							</span>
						</div>
						<div class="agent-overview-tile">
							<span class="agent-overview-icon runtime-icon">@Icon("cpu", 16)</span>
							<span class="agent-overview-content">
								<small>Runtime</small>
								<span class="agent-runtime-badge">{ string(agent.Type) }</span>
							</span>
						</div>
						<div class="agent-overview-tile agent-overview-wide">
							<span class="agent-overview-icon">@Icon("zap", 16)</span>
							<span class="agent-overview-content">
								<small>Tags</small>
								<div class="agent-tag-list">@TagChips(agentDisplayTags(agent, projects))</div>
							</span>
						</div>
					</div>
				</div>
				<div id="tasks" class="card">
					@SectionHeader("Assigned Tasks", "Current and historical work assigned to this agent.")
					@TaskTable(tasks, []domain.Agent{agent}, projects)
				</div>
				<div id="runs" class="card">
					@SectionHeader("Run History", "Execution history, logs and raw agent output.")
					@Runs(runs)
				</div>
				<div id="configuration" class="agent-config-card">
					@SectionHeader("Configuration", "Adapter, environment and prompt settings.")
					<form hx-post={ "/agents/" + agent.ID + "/edit" } data-success="Agent configuration saved." hx-target="body" hx-swap="outerHTML" class="agent-config-form">
						<section class="agent-config-section">
							<div class="agent-config-section-header">
								<span class="agent-config-section-icon">@Icon("users", 16)</span>
								<div>
									<h3>Identity</h3>
									<p>Name, role, hierarchy and organization tags.</p>
								</div>
							</div>
							<div class="agent-config-grid">
								@FormField("name", "Name", "Public display name for this agent.") {
									@TextField("name", agent.Name, "Agent name", false)
								}
								@FormField("title", "Title", "Role shown in listings and profile cards.") {
									@TextField("title", agent.Title, "Job title / role", false)
								}
								@FormField("reports_to_id", "Reports to", "Optional parent agent in the organization chart.") {
									<select id="reports_to_id" name="reports_to_id" class="pc-input pc-select">
										<option value="">Top-level agent</option>
										for _, optionAgent := range agents {
											if optionAgent.ID != agent.ID {
												<option value={ optionAgent.ID } selected?={ optionAgent.ID == agent.ReportsToID }>{ optionAgent.Name + " — " + optionAgent.Title }</option>
											}
										}
									</select>
								}
								@FormField("description", "Description", "Responsibilities, scope and expected behavior.") {
									@TextareaField("description", agent.Description, "Description and responsibilities", 4, false)
								}
							</div>
							@FormField("tags", "Tags", "Use tags to organize agents and project affinity.") {
								@TagMultiSelectField("tags", agent.Tags, availableAgentTagsJSON(agents, projects))
							}
						</section>
						<section class="agent-config-section">
							<div class="agent-config-section-header">
								<span class="agent-config-section-icon">@Icon("book", 16)</span>
								<div>
									<h3>Prompt & instructions</h3>
									<p>Attach an instruction file or add a focused system prompt.</p>
								</div>
							</div>
							@FormField("instruction_file", "Instruction file", "Absolute path to a markdown file injected into the system prompt at runtime.") {
								@TextField("instruction_file", agent.InstructionFile, "/absolute/path/AGENTS.md", false)
							}
							@FormField("system_prompt", "System prompt", "Optional custom behavior layered on top of skills and capabilities.") {
								@TextareaField("system_prompt", agent.SystemPrompt, "Optional custom agent prompt", 6, false)
							}
						</section>
						<section class="agent-config-section">
							<div class="agent-config-section-header">
								<span class="agent-config-section-icon">@Icon("cpu", 16)</span>
								<div>
									<h3>Adapter parameters</h3>
									<p>Runtime arguments, configuration overrides and environment variables.</p>
								</div>
							</div>
							<div class="agent-config-grid">
								@FormField("extra_args", "Extra arguments", "One argument per line. Example: --foo or --bar=value.") {
									@TextareaField("extra_args", strings.Join(agent.ExtraArgs, "\n"), "--foo\n--bar=value", 4, false)
								}
								@FormField("config", "Adapter config", "Key-value overrides for this agent runtime.") {
									@TextareaField("config", mapToLines(agent.Config), "key=value", 4, false)
								}
							</div>
							@FormField("env", "Environment variables", "Values are hidden by default and injected only into this agent runtime.") {
								@EnvEditorField(agent.Env)
							}
						</section>
						<div class="agent-config-actions">
							<button class="pc-btn pc-btn-primary" type="submit">@Icon("check", 16) Save configuration</button>
						</div>
					</form>
				</div>
			</div>
			<aside class="side-column">
				<div id="permissions" class="card">
					<h2>Permissions Preset</h2>
					<form hx-post={ "/agents/" + agent.ID + "/permissions" } hx-target="body" hx-swap="outerHTML" class="stacked" data-success="Permissions applied.">
						<select name="permission_preset">@templ.Raw(permissionPresetOptionsHTML(agent.Permissions))</select>
						<button type="submit">Apply preset</button>
					</form>
				</div>
				<div class="card">
					<details>
						<summary class="advanced-summary">Advanced manual permissions</summary>
						<form hx-post={ "/agents/" + agent.ID + "/permissions" } hx-target="body" hx-swap="outerHTML" class="stacked permission-list compact-permissions">
							@templ.Raw(permissionCheckboxesHTML(agent.Permissions))
							<button type="submit">Save permissions</button>
						</form>
					</details>
				</div>
				<div class="card">
					<h2>Manual Skills</h2>
					@templ.Raw(agentSkillFormHTML(agent.ID, skills, agent.SkillIDs))
				</div>
				<div class="card">
					<form hx-post={ "/agents/" + agent.ID + "/delete" } hx-confirm="Delete this agent? This cannot be undone." data-success="Agent deleted." hx-target="body" hx-swap="outerHTML">
						<button class="danger" type="submit">Delete agent</button>
					</form>
				</div>
			</aside>
		</section>
	}
}

templ agentDetailAction() {
	<a class="button secondary" href="/agents">Voltar</a>
}

func permissionPresetOptionsHTML(selected []domain.AgentPermission) string {
	var b strings.Builder
	_ = renderPermissionPresetOptions(&b, selected)
	return b.String()
}

func permissionCheckboxesHTML(selected []domain.AgentPermission) string {
	var b strings.Builder
	_ = renderPermissionCheckboxes(&b, selected)
	return b.String()
}

func agentSkillFormHTML(agentID string, skills []domain.Skill, selected []string) string {
	var b strings.Builder
	_ = renderAgentSkillForm(&b, agentID, skills, selected)
	return b.String()
}

func agentDescriptionText(value string) string {
	if strings.TrimSpace(value) == "" {
		return "No description provided yet."
	}
	return value
}

func agentFallbackText(value string, fallback string) string {
	if strings.TrimSpace(value) == "" {
		return fallback
	}
	return value
}

func agentReportsToText(agents []domain.Agent, reportsToID string) string {
	if strings.TrimSpace(reportsToID) == "" {
		return "Top-level agent"
	}
	name := agentName(agents, reportsToID)
	if strings.TrimSpace(name) == "" {
		return "Unknown agent"
	}
	return name
}
